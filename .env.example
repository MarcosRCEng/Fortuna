NODE_ENV=development
API_PORT=3000
WEB_PORT=5173
DATABASE_URL=postgresql://fortuna:fortuna_dev@localhost:5432/fortuna
FORTUNA_PERSISTENCE=memory
LOG_LEVEL=debug

MARKET_DATA_PROVIDER=mock
BRAPI_BASE_URL=https://brapi.dev/api
BRAPI_API_TOKEN=
BRAPI_TIMEOUT_MS=5000
BRAPI_CACHE_TTL_SECONDS=900
BRAPI_MAX_SYMBOLS_PER_REQUEST=1
MARKET_DATA_ALLOW_REAL_DATA=false
MARKET_DATA_ALLOWED_SYMBOLS=PETR4,VALE3,ITUB4,MGLU3

# Para usar dados reais em desenvolvimento:
# 1. Crie uma conta em https://brapi.dev
# 2. Gere uma chave de API no dashboard
# 3. Copie este arquivo para .env.local ou .env.development
# 4. Defina MARKET_DATA_PROVIDER=brapi
# 5. Defina MARKET_DATA_ALLOW_REAL_DATA=true
# 6. Preencha BRAPI_API_TOKEN com seu token local
# 7. Nunca versionar arquivos .env reais
